<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kiosk — fullscreen OWL component for operators -->
    <record id="action_dnj_shopfloor_kiosk" model="ir.actions.client">
        <field name="name">Kiosk DNJ</field>
        <field name="tag">dnj_shopfloor_kiosk_action</field>
        <field name="target">fullscreen</field>
    </record>

    <!-- Manager dashboard — all machines at a glance -->
    <record id="action_dnj_shopfloor_dashboard" model="ir.actions.client">
        <field name="name">Dashboard maszyn</field>
        <field name="tag">dnj_shopfloor_dashboard_action</field>
        <field name="target">main</field>
    </record>

    <menuitem id="menu_dnj_shopfloor_dashboard"
              name="Dashboard"
              parent="dnj_shopfloor.menu_dnj_shopfloor_root"
              action="dnj_shopfloor.action_dnj_shopfloor_dashboard"
              groups="mrp.group_mrp_manager"
              sequence="5"/>
</odoo>
