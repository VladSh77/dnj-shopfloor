<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════
         dnj.operator
    ══════════════════════════════════════════════════════════════════════ -->

    <record id="view_dnj_operator_tree" model="ir.ui.view">
        <field name="name">dnj.operator.tree</field>
        <field name="model">dnj.operator</field>
        <field name="arch" type="xml">
            <tree string="Operators">
                <field name="name"/>
                <field name="workcenter_ids" widget="many2many_tags"/>
                <field name="session_count"/>
                <field name="last_session_date"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_dnj_operator_form" model="ir.ui.view">
        <field name="name">dnj.operator.form</field>
        <field name="model">dnj.operator</field>
        <field name="arch" type="xml">
            <form string="Operator">
                <sheet>
                    <field name="active" widget="boolean_toggle"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="pin_hash" password="True"
                                   string="PIN (SHA-256)"
                                   help="SHA-256 hash. Use Set PIN button."/>
                        </group>
                        <group>
                            <field name="workcenter_ids" widget="many2many_tags"/>
                            <field name="last_session_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="note" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Sessions" name="sessions">
                            <field name="session_ids" readonly="1">
                                <tree>
                                    <field name="start_time"/>
                                    <field name="workcenter_id"/>
                                    <field name="workorder_id"/>
                                    <field name="state"/>
                                    <field name="duration_total" string="Total (min)"/>
                                    <field name="qty_produced"/>
                                    <field name="qty_scrap"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dnj_operator_search" model="ir.ui.view">
        <field name="name">dnj.operator.search</field>
        <field name="model">dnj.operator</field>
        <field name="arch" type="xml">
            <search string="Search Operators">
                <field name="name"/>
                <field name="workcenter_ids"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_dnj_operator" model="ir.actions.act_window">
        <field name="name">Operators</field>
        <field name="res_model">dnj.operator</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <!-- defined here so operator form can reference it -->
    <record id="action_dnj_kiosk_session_by_operator" model="ir.actions.act_window">
        <field name="name">Sessions</field>
        <field name="res_model">dnj.kiosk.session</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('operator_id', '=', active_id)]</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         dnj.kiosk.session
    ══════════════════════════════════════════════════════════════════════ -->

    <record id="view_dnj_kiosk_session_tree" model="ir.ui.view">
        <field name="name">dnj.kiosk.session.tree</field>
        <field name="model">dnj.kiosk.session</field>
        <field name="arch" type="xml">
            <tree string="Sessions"
                  decoration-success="state == 'progress'"
                  decoration-warning="state == 'paused'">
                <field name="start_time"/>
                <field name="operator_id"/>
                <field name="workcenter_id"/>
                <field name="workorder_id"/>
                <field name="state"/>
                <field name="duration_total" string="Total (min)"/>
                <field name="duration_net" string="Net (min)"/>
                <field name="qty_produced"/>
                <field name="qty_scrap"/>
            </tree>
        </field>
    </record>

    <record id="view_dnj_kiosk_session_form" model="ir.ui.view">
        <field name="name">dnj.kiosk.session.form</field>
        <field name="model">dnj.kiosk.session</field>
        <field name="arch" type="xml">
            <form string="Kiosk Session" create="false">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,test_print,confirmed,progress,done"/>
                </header>
                <sheet>
                    <group>
                        <group string="Who / Where">
                            <field name="operator_id" readonly="1"/>
                            <field name="workcenter_id" readonly="1"/>
                            <field name="workorder_id" readonly="1"/>
                        </group>
                        <group string="Timing">
                            <field name="start_time" readonly="1"/>
                            <field name="end_time" readonly="1"/>
                            <field name="work_start_time" readonly="1"/>
                            <field name="work_end_time" readonly="1"/>
                            <field name="duration_total" readonly="1"/>
                            <field name="duration_net" readonly="1"/>
                            <field name="duration_pause" readonly="1"/>
                        </group>
                        <group string="Test Print">
                            <field name="test_print_qty" readonly="1"/>
                            <field name="test_print_confirmed" readonly="1"/>
                        </group>
                        <group string="Production">
                            <field name="qty_produced" readonly="1"/>
                            <field name="qty_scrap" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Pauses" name="pauses">
                            <field name="pause_ids" readonly="1">
                                <tree>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                    <field name="reason"/>
                                    <field name="duration_minutes" string="Min"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Event Log" name="log">
                            <field name="log_ids" readonly="1">
                                <tree>
                                    <field name="timestamp"/>
                                    <field name="event_type" widget="badge"/>
                                    <field name="qty"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_dnj_kiosk_session" model="ir.actions.act_window">
        <field name="name">Kiosk Sessions</field>
        <field name="res_model">dnj.kiosk.session</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         dnj.workorder.log
    ══════════════════════════════════════════════════════════════════════ -->

    <record id="view_dnj_workorder_log_tree" model="ir.ui.view">
        <field name="name">dnj.workorder.log.tree</field>
        <field name="model">dnj.workorder.log</field>
        <field name="arch" type="xml">
            <tree string="Event Log" create="false" delete="false" edit="false"
                  decoration-success="event_type in ('start','confirm_ready')"
                  decoration-warning="event_type in ('pause','test_print')"
                  decoration-danger="event_type in ('scrap','error')">
                <field name="timestamp"/>
                <field name="operator_id"/>
                <field name="workcenter_id"/>
                <field name="workorder_id"/>
                <field name="event_type"/>
                <field name="qty"/>
                <field name="note"/>
            </tree>
        </field>
    </record>

    <record id="action_dnj_workorder_log" model="ir.actions.act_window">
        <field name="name">Event Log</field>
        <field name="res_model">dnj.workorder.log</field>
        <field name="view_mode">tree</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         Menu
    ══════════════════════════════════════════════════════════════════════ -->

    <menuitem id="menu_dnj_shopfloor_root"
              name="DNJ Shopfloor"
              sequence="10"/>

    <menuitem id="menu_dnj_shopfloor_dashboard"
              name="Dashboard"
              parent="menu_dnj_shopfloor_root"
              action="dnj_shopfloor.action_dnj_shopfloor_dashboard"
              sequence="5"/>

    <menuitem id="menu_dnj_shopfloor_kiosk"
              name="Kiosk"
              parent="menu_dnj_shopfloor_root"
              action="action_dnj_shopfloor_kiosk"
              sequence="10"/>

    <menuitem id="menu_dnj_kiosk_session"
              name="Sessions"
              parent="menu_dnj_shopfloor_root"
              action="action_dnj_kiosk_session"
              sequence="20"/>

    <menuitem id="menu_dnj_workorder_log"
              name="Event Log"
              parent="menu_dnj_shopfloor_root"
              action="action_dnj_workorder_log"
              sequence="30"/>

    <menuitem id="menu_dnj_shopfloor_config"
              name="Configuration"
              parent="menu_dnj_shopfloor_root"
              sequence="90"/>

    <menuitem id="menu_dnj_operator"
              name="Operators"
              parent="menu_dnj_shopfloor_config"
              action="action_dnj_operator"
              sequence="10"/>

</odoo>
