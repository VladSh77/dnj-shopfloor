<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<!-- ══════════════════════════════════════════════════════════════════
     Dashboard root
══════════════════════════════════════════════════════════════════ -->
<t t-name="dnj_shopfloor.Dashboard" owl="1">
    <div style="min-height:100vh;background:#111209;color:#E8E6D0;font-family:'Segoe UI',system-ui,sans-serif;">

        <!-- Header -->
        <div class="d-flex align-items-center px-4"
             style="height:56px;background:#1C1C12;border-bottom:2px solid #C9A227;">
            <img src="https://dnj.pl/img/logo.png" alt="DNJ"
                 style="height:32px;margin-right:10px;" onerror="this.style.display='none'"/>
            <span style="color:#C9A227;font-weight:700;letter-spacing:.12em;text-transform:uppercase;font-size:.95rem;">
                Dashboard Produkcji
            </span>

            <!-- summary badges -->
            <div class="d-flex gap-3 ms-4">
                <span class="badge px-3 py-2"
                      style="background:#1e4020;color:#60c060;font-size:.8rem;border-radius:8px;">
                    ▶ Praca: <t t-esc="activeCount"/>
                </span>
                <span class="badge px-3 py-2"
                      style="background:#4A3A00;color:#C9A227;font-size:.8rem;border-radius:8px;">
                    ⏸ Pauza: <t t-esc="pausedCount"/>
                </span>
                <span class="badge px-3 py-2"
                      style="background:#222218;color:#888870;font-size:.8rem;border-radius:8px;">
                    ○ Wolna: <t t-esc="idleCount"/>
                </span>
            </div>

            <div class="ms-auto d-flex align-items-center gap-3">
                <span t-if="state.lastUpdate"
                      style="color:#555540;font-size:.75rem;">
                    Aktualizacja: <t t-esc="state.lastUpdate"/>
                </span>
                <span style="color:#333320;font-size:.72rem;">auto-refresh 30s</span>
            </div>
        </div>

        <!-- Loading -->
        <t t-if="state.loading">
            <div class="d-flex justify-content-center align-items-center"
                 style="height:60vh;">
                <div class="spinner-border"
                     style="width:3rem;height:3rem;color:#C9A227;border-width:3px;"/>
            </div>
        </t>

        <!-- Machine grid -->
        <div t-else="" class="p-4">
            <div class="row g-3">
                <t t-foreach="state.machines" t-as="wc" t-key="wc.id">
                    <div class="col-12 col-md-6 col-xl-4">
                        <MachineCard wc="wc" tick="state.tick"/>
                    </div>
                </t>
            </div>
        </div>
    </div>
</t>

<!-- ══════════════════════════════════════════════════════════════════
     MachineCard
══════════════════════════════════════════════════════════════════ -->
<t t-name="dnj_shopfloor.MachineCard" owl="1">
    <div class="h-100"
         t-attf-style="background:#1C1C12;border:2px solid #{isActive ? '#2D5C2D' : isPaused ? '#7A6000' : '#333320'};border-radius:16px;overflow:hidden;transition:border-color .4s;">

        <!-- Machine name bar -->
        <div class="d-flex align-items-center justify-content-between px-3 py-2"
             t-attf-style="background:#{statusColor};border-bottom:1px solid #333320;">
            <div class="d-flex align-items-center gap-2">
                <!-- network ping dot -->
                <t t-if="isMonitored">
                    <span t-attf-style="display:inline-block;width:9px;height:9px;border-radius:50%;background:#{isOnline ? '#60c060' : '#c03030'};box-shadow:0 0 #{isOnline ? '6px #60c060' : '4px #c03030'};"
                          t-att-title="pingLabel"/>
                </t>
                <span class="fw-bold" style="font-size:1rem;" t-esc="props.wc.name"/>
                <t t-if="props.wc.code">
                    <span style="font-size:.72rem;color:#C9A227;letter-spacing:.1em;"
                          t-esc="props.wc.code"/>
                </t>
            </div>
            <div class="d-flex align-items-center gap-2">
                <t t-if="isMonitored">
                    <span t-attf-style="font-size:.68rem;color:#{isOnline ? '#3a8a3a' : '#883030'};"
                          t-esc="pingLabel"/>
                </t>
                <span class="badge px-3 py-1 fw-semibold"
                      t-attf-style="background:rgba(0,0,0,.3);color:#{statusTextColor};font-size:.78rem;border-radius:8px;"
                      t-esc="statusLabel"/>
            </div>
        </div>

        <!-- Body -->
        <div class="p-3">
            <t t-if="!sess">
                <!-- Idle machine -->
                <div class="text-center py-4" style="color:#555540;">
                    <div style="font-size:2.5rem;margin-bottom:.5rem;">⚙</div>
                    <div style="font-size:.9rem;">Maszyna wolna</div>
                </div>
            </t>
            <t t-else="">
                <!-- Operator + work order info -->
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <div style="font-size:.72rem;color:#888870;text-transform:uppercase;letter-spacing:.08em;">
                            Operator
                        </div>
                        <div class="fw-semibold" style="color:#C9A227;" t-esc="sess.operator"/>
                    </div>
                    <t t-if="sess.workorder">
                        <div class="text-end">
                            <div style="font-size:.72rem;color:#888870;text-transform:uppercase;letter-spacing:.08em;">
                                Zlecenie
                            </div>
                            <div class="fw-semibold" style="font-size:.9rem;" t-esc="sess.workorder"/>
                        </div>
                    </t>
                </div>

                <!-- Product -->
                <t t-if="sess.product">
                    <div class="mb-3 px-2 py-1"
                         style="background:#222218;border-radius:8px;font-size:.85rem;color:#E8E6D0;"
                         t-esc="sess.product"/>
                </t>

                <!-- Timer -->
                <t t-if="isActive">
                    <div class="text-center mb-2"
                         style="font-size:2.4rem;font-weight:700;font-variant-numeric:tabular-nums;letter-spacing:.04em;color:#E8E6D0;">
                        <t t-esc="fmtTime(timerSec)"/>
                    </div>
                </t>
                <t t-elif="isPaused">
                    <div class="text-center mb-2 py-2"
                         style="background:#2A2200;border-radius:10px;color:#C9A227;font-weight:600;">
                        ⏸ PAUZA
                    </div>
                </t>

                <!-- TIME BAR -->
                <t t-if="isActive and plannedSec">
                    <div class="mb-2">
                        <div class="d-flex justify-content-between mb-1"
                             style="font-size:.72rem;color:#888870;">
                            <span>Czas</span>
                            <span t-attf-style="color:#{timeBarColor};font-weight:600;">
                                <t t-esc="fmtTime(timerSec)"/> / <t t-esc="fmtTime(plannedSec)"/>
                                (<t t-esc="timePct"/>%)
                            </span>
                        </div>
                        <div style="height:16px;background:#222218;border-radius:8px;overflow:hidden;">
                            <div t-attf-style="width:#{timeBarWidth}%;height:100%;background:#{timeBarColor};border-radius:8px;transition:width 1s;"/>
                        </div>
                        <t t-if="isOvertime">
                            <div class="mt-1 fw-bold" style="color:#c03030;font-size:.8rem;">
                                ⚠ +<t t-esc="fmtTime(overtimeSec)"/>
                            </div>
                        </t>
                    </div>
                </t>

                <!-- Qty bar -->
                <t t-if="sess.qty_production">
                    <div class="mb-1 d-flex justify-content-between"
                         style="font-size:.72rem;color:#888870;">
                        <span>Wykonano</span>
                        <span><t t-esc="sess.qty_produced"/> / <t t-esc="sess.qty_production"/> szt. (<t t-esc="progressPct"/>%)</span>
                    </div>
                    <div style="height:8px;background:#333320;border-radius:4px;overflow:hidden;margin-bottom:.5rem;">
                        <div t-attf-style="width:#{progressPct}%;height:100%;background:#1e3050;border-radius:4px;transition:width .5s;"/>
                    </div>
                </t>

                <!-- Modbus live data -->
                <t t-if="hasModbus and isOnline">
                    <div class="d-flex gap-2 mb-2" style="font-size:.78rem;">
                        <span t-attf-style="background:#{machineRunning ? '#1e4020' : '#2a1a00'};color:#{machineRunning ? '#60c060' : '#C9A227'};border-radius:6px;padding:2px 8px;">
                            <t t-esc="machineRunning ? '▶ Running' : '■ Stopped'"/>
                        </span>
                        <t t-if="machineSpeed">
                            <span style="background:#1a1a2e;color:#9090b0;border-radius:6px;padding:2px 8px;">
                                <t t-esc="machineSpeed"/> sh/h
                            </span>
                        </t>
                        <t t-if="machineCounter">
                            <span style="background:#1a1a2e;color:#9090b0;border-radius:6px;padding:2px 8px;">
                                Σ <t t-esc="machineCounter"/>
                            </span>
                        </t>
                    </div>
                </t>

                <!-- Scrap -->
                <t t-if="sess.qty_scrap">
                    <div style="font-size:.8rem;color:#e08080;">
                        Braki: <t t-esc="sess.qty_scrap"/> szt.
                    </div>
                </t>
            </t>
        </div>
    </div>
</t>

</templates>
