<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ═══════════════════════════════════════════════════════════════════════
         KioskMain — root container
    ═══════════════════════════════════════════════════════════════════════════ -->
    <t t-name="dnj_shopfloor.KioskMain" owl="1">
        <div class="dnj-kiosk d-flex flex-column" style="height:100vh; overflow:hidden; background:#12121f; color:#e8e8f0; font-family:'Segoe UI',sans-serif;">

            <!-- header -->
            <div class="d-flex align-items-center px-4 gap-3 flex-shrink-0"
                 style="height:56px; background:#1c1c30; border-bottom:2px solid #2e2e50;">
                <span class="fw-bold fs-5 text-white">DNJ Shopfloor</span>
                <t t-if="state.selectedWorkcenter">
                    <span class="text-secondary">›</span>
                    <span class="text-info" t-esc="state.selectedWorkcenter.name"/>
                </t>
                <t t-if="state.selectedWorkorder and state.screen === 'detail'">
                    <span class="text-secondary">›</span>
                    <span class="text-white small" t-esc="state.selectedWorkorder.name"/>
                </t>
            </div>

            <!-- loading -->
            <t t-if="state.loading">
                <div class="d-flex justify-content-center align-items-center flex-grow-1">
                    <div class="spinner-border text-info" role="status" style="width:3rem;height:3rem;"/>
                </div>
            </t>

            <!-- screens -->
            <t t-elif="state.screen === 'workcenter'">
                <WorkcenterSelector
                    workcenters="state.workcenters"
                    onSelect.bind="selectWorkcenter"
                />
            </t>
            <t t-elif="state.screen === 'workorders'">
                <WorkOrderList
                    workorders="state.workorders"
                    workcenter="state.selectedWorkcenter"
                    onSelect.bind="selectWorkorder"
                    onBack.bind="goBack"
                    onRefresh.bind="refreshWorkorders"
                />
            </t>
            <t t-elif="state.screen === 'detail'">
                <WorkOrderDetail
                    workorder="state.selectedWorkorder"
                    saving="state.saving"
                    onStart.bind="startWork"
                    onFinish.bind="finishWork"
                    onBack.bind="goBack"
                />
            </t>

        </div>
    </t>

    <!-- ═══════════════════════════════════════════════════════════════════════
         WorkcenterSelector — grid of machines
    ═══════════════════════════════════════════════════════════════════════════ -->
    <t t-name="dnj_shopfloor.WorkcenterSelector" owl="1">
        <div class="flex-grow-1 overflow-auto p-4">
            <h4 class="text-center text-secondary mb-4 text-uppercase tracking-wide"
                style="letter-spacing:.12em;">Wybierz maszynę</h4>

            <t t-if="!workcenters.length">
                <div class="text-center text-secondary mt-5">
                    Brak dostępnych maszyn
                </div>
            </t>

            <div class="row g-3 justify-content-center">
                <t t-foreach="workcenters" t-as="wc" t-key="wc.id">
                    <div class="col-6 col-md-4 col-lg-3">
                        <button class="btn w-100 h-100 d-flex flex-column align-items-center justify-content-center gap-2 p-4"
                                style="min-height:130px; background:#1c1c30; border:2px solid #2e2e50; border-radius:14px; color:#e8e8f0; transition:border-color .15s,background .15s;"
                                t-on-mouseenter="(ev) => { ev.currentTarget.style.borderColor='#4c4cff'; ev.currentTarget.style.background='#22223a'; }"
                                t-on-mouseleave="(ev) => { ev.currentTarget.style.borderColor='#2e2e50'; ev.currentTarget.style.background='#1c1c30'; }"
                                t-on-click="() => props.onSelect(wc)">
                            <span class="fw-bold fs-5" t-esc="wc.name"/>
                            <t t-if="wc.code">
                                <span class="badge bg-secondary" t-esc="wc.code"/>
                            </t>
                        </button>
                    </div>
                </t>
            </div>
        </div>
    </t>

    <!-- ═══════════════════════════════════════════════════════════════════════
         WorkOrderList — list of active work orders for a workcenter
    ═══════════════════════════════════════════════════════════════════════════ -->
    <t t-name="dnj_shopfloor.WorkOrderList" owl="1">
        <div class="d-flex flex-column flex-grow-1 overflow-hidden">

            <!-- toolbar -->
            <div class="d-flex align-items-center gap-3 px-4 py-2 flex-shrink-0"
                 style="background:#1c1c30; border-bottom:1px solid #2e2e50;">
                <button class="btn btn-outline-secondary btn-sm" t-on-click="props.onBack">
                    ← Wróć
                </button>
                <input t-ref="barcodeInput"
                       class="form-control form-control-sm"
                       style="max-width:280px; background:#12121f; border-color:#2e2e50; color:#e8e8f0;"
                       placeholder="🔍 Skanuj lub wpisz nr zlecenia + Enter"
                       t-on-keydown="onBarcodeKey"
                />
                <button class="btn btn-outline-info btn-sm ms-auto" t-on-click="props.onRefresh">
                    ↻ Odśwież
                </button>
                <span class="text-secondary small">
                    <t t-esc="workorders.length"/> zleceń
                </span>
            </div>

            <!-- list -->
            <div class="overflow-auto flex-grow-1 p-3">
                <t t-if="!workorders.length">
                    <div class="text-center text-secondary mt-5">
                        Brak aktywnych zleceń dla tej maszyny
                    </div>
                </t>

                <t t-foreach="workorders" t-as="wo" t-key="wo.id">
                    <div class="d-flex align-items-center justify-content-between px-4 py-3 mb-2"
                         style="background:#1c1c30; border:1px solid #2e2e50; border-radius:12px; cursor:pointer; transition:border-color .15s;"
                         t-on-mouseenter="(ev) => ev.currentTarget.style.borderColor = '#4c4cff'"
                         t-on-mouseleave="(ev) => ev.currentTarget.style.borderColor = '#2e2e50'"
                         t-on-click="() => props.onSelect(wo)">

                        <div>
                            <div class="fw-bold" t-esc="wo.name"/>
                            <div class="text-secondary small mt-1"
                                 t-esc="wo.product_id ? wo.product_id[1] : '—'"/>
                            <t t-if="wo.production_id">
                                <div class="text-secondary" style="font-size:.75rem;"
                                     t-esc="'MO: ' + wo.production_id[1]"/>
                            </t>
                        </div>

                        <div class="d-flex flex-column align-items-end gap-2">
                            <span t-attf-class="#{stateBadge(wo.state)}" t-esc="stateLabel(wo.state)"/>
                            <span class="text-secondary small">
                                <t t-esc="wo.qty_produced"/> / <t t-esc="wo.qty_production"/> szt.
                            </span>
                            <t t-if="wo.date_planned_start">
                                <span class="text-secondary" style="font-size:.72rem;"
                                      t-esc="new Date(wo.date_planned_start).toLocaleString('pl-PL', {day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'})"/>
                            </t>
                        </div>

                    </div>
                </t>
            </div>
        </div>
    </t>

    <!-- ═══════════════════════════════════════════════════════════════════════
         WorkOrderDetail — start / stop + qty
    ═══════════════════════════════════════════════════════════════════════════ -->
    <t t-name="dnj_shopfloor.WorkOrderDetail" owl="1">
        <div class="d-flex flex-column flex-grow-1 overflow-hidden">

            <!-- toolbar -->
            <div class="d-flex align-items-center gap-3 px-4 py-2 flex-shrink-0"
                 style="background:#1c1c30; border-bottom:1px solid #2e2e50;">
                <button class="btn btn-outline-secondary btn-sm" t-on-click="props.onBack">
                    ← Wróć
                </button>
                <span class="fw-semibold" t-esc="props.workorder.name"/>

                <!-- state badge -->
                <span class="ms-auto">
                    <t t-if="props.workorder.state === 'progress'">
                        <span class="badge bg-primary fs-6">W TOKU</span>
                    </t>
                    <t t-elif="props.workorder.state === 'ready'">
                        <span class="badge bg-success fs-6">GOTOWE</span>
                    </t>
                    <t t-else="">
                        <span class="badge bg-secondary fs-6" t-esc="props.workorder.state"/>
                    </t>
                </span>
            </div>

            <!-- content -->
            <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1 p-4">
                <div class="p-4 p-md-5"
                     style="background:#1c1c30; border:1px solid #2e2e50; border-radius:20px; min-width:320px; max-width:520px; width:100%;">

                    <!-- product -->
                    <div class="text-secondary text-uppercase small mb-1" style="letter-spacing:.1em;">Produkt</div>
                    <div class="fw-bold fs-4 mb-4"
                         t-esc="props.workorder.product_id ? props.workorder.product_id[1] : '—'"/>

                    <!-- production order -->
                    <t t-if="props.workorder.production_id">
                        <div class="text-secondary small mb-4"
                             t-esc="'Zlecenie prod.: ' + props.workorder.production_id[1]"/>
                    </t>

                    <!-- qty counters -->
                    <div class="d-flex justify-content-around mb-4">
                        <div class="text-center">
                            <div class="text-secondary small">Zlecono</div>
                            <div class="fw-bold" style="font-size:2.4rem;" t-esc="props.workorder.qty_production"/>
                        </div>
                        <div class="text-center">
                            <div class="text-secondary small">Wykonano</div>
                            <div class="fw-bold text-success" style="font-size:2.4rem;" t-esc="props.workorder.qty_produced"/>
                        </div>
                    </div>

                    <!-- qty input (shown only when finishing) -->
                    <t t-if="props.workorder.state === 'progress'">
                        <div class="mb-4 text-center">
                            <label class="text-secondary small d-block mb-2">Ilość do zarejestrowania</label>
                            <input type="number" min="0" step="1"
                                   class="form-control text-center fw-bold"
                                   style="font-size:1.8rem; background:#12121f; border-color:#2e2e50; color:#e8e8f0; max-width:160px; margin:auto; border-radius:10px;"
                                   t-att-value="qty.value"
                                   t-on-change="onQtyChange"
                            />
                        </div>
                    </t>

                    <!-- action buttons -->
                    <div class="d-flex gap-3 justify-content-center">
                        <t t-if="props.workorder.state !== 'progress'">
                            <button class="btn btn-success btn-lg px-5"
                                    style="border-radius:12px; font-size:1.1rem;"
                                    t-att-disabled="props.saving"
                                    t-on-click="props.onStart">
                                <t t-if="props.saving">
                                    <span class="spinner-border spinner-border-sm me-2"/>
                                </t>
                                ▶ START
                            </button>
                        </t>
                        <t t-if="props.workorder.state === 'progress'">
                            <button class="btn btn-danger btn-lg px-5"
                                    style="border-radius:12px; font-size:1.1rem;"
                                    t-att-disabled="props.saving"
                                    t-on-click="onFinishClick">
                                <t t-if="props.saving">
                                    <span class="spinner-border spinner-border-sm me-2"/>
                                </t>
                                ■ STOP
                            </button>
                        </t>
                    </div>

                </div>
            </div>
        </div>
    </t>

</templates>
