<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<!--
    DNJ Shopfloor Kiosk - OWL 2 templates
    Brand palette:
      gold   : #C9A227   (logo gold)
      green  : #2D5C2D   (action / confirm)
      dark   : #111209   (page background)
      card   : #1C1C12   (card / panel)
      border : #333320   (dividers)
      text   : #E8E6D0   (primary text)
      muted  : #888870   (secondary text)
-->

<!-- ══════════════════════════════════════════════════════════════════
     ROOT — KioskMain
══════════════════════════════════════════════════════════════════ -->
<t t-name="dnj_shopfloor.KioskMain" owl="1">
    <div class="dnj-kiosk d-flex flex-column"
         style="height:100vh;overflow:hidden;background:#111209;color:#E8E6D0;font-family:'Segoe UI',system-ui,sans-serif;user-select:none;">

        <!-- ── Header bar ── -->
        <div class="d-flex align-items-center px-4 flex-shrink-0"
             style="height:56px;background:#1C1C12;border-bottom:2px solid #C9A227;">

            <!-- Logo -->
            <img src="https://dnj.pl/img/logo.png"
                 alt="DNJ" style="height:34px;margin-right:12px;" onerror="this.style.display='none'"/>
            <span class="fw-bold me-3"
                  style="color:#C9A227;font-size:.95rem;letter-spacing:.12em;text-transform:uppercase;">
                Shop Floor
            </span>

            <!-- breadcrumb -->
            <t t-if="state.workcenter">
                <span style="color:#555540;">›</span>
                <span class="fw-semibold mx-2" style="color:#E8E6D0;" t-esc="state.workcenter ? state.workcenter.name : ''"/>
            </t>
            <t t-if="state.operator">
                <span style="color:#555540;">›</span>
                <span class="mx-2" style="color:#C9A227;" t-esc="state.operator.name"/>
            </t>

            <!-- logout button -->
            <div class="ms-auto">
                <t t-if="state.operator and state.screen !== 'pin'">
                    <button class="btn btn-sm"
                            style="border:1px solid #555540;color:#888870;font-size:.75rem;border-radius:8px;"
                            t-on-click="logout"
                            t-att-disabled="state.saving">
                        Wyloguj
                    </button>
                </t>
            </div>
        </div>

        <!-- ── Loading overlay ── -->
        <t t-if="state.loading">
            <div class="d-flex flex-column justify-content-center align-items-center flex-grow-1">
                <div class="spinner-border mb-3"
                     style="width:3.5rem;height:3.5rem;color:#C9A227;border-width:3px;"/>
                <div style="color:#888870;">Ładowanie...</div>
            </div>
        </t>

        <!-- ── Screens ── -->
        <t t-elif="state.screen === 'machine'">
            <WorkcenterSelector workcenters="state.workcenters"
                                loading="state.loading"
                                onSelect.bind="selectWorkcenter"/>
        </t>
        <t t-elif="state.screen === 'pin'">
            <PinScreen workcenter="state.workcenter"
                       onAuth.bind="onAuth"
                       onBack="() => { state.screen = 'machine'; state.workcenter = null; }"/>
        </t>
        <t t-elif="state.screen === 'queue'">
            <WorkOrderQueue workorders="state.workorders"
                            operator="state.operator"
                            workcenter="state.workcenter"
                            loading="state.loading"
                            onSelect.bind="selectWorkorder"
                            onRefresh.bind="_loadWorkorders"
                            onLogout.bind="logout"/>
        </t>
        <t t-elif="state.screen === 'test_print'">
            <TestPrintScreen workorder="state.workorder"
                             operator="state.operator"
                             workcenter="state.workcenter"
                             saving="state.saving"
                             onConfirm.bind="onTestPrintConfirm"
                             onBack="() => { state.screen = 'queue'; }"/>
        </t>
        <t t-elif="state.screen === 'work'">
            <WorkScreen workorder="state.workorder"
                        operator="state.operator"
                        workcenter="state.workcenter"
                        sessionState="state.sessionState"
                        timerSec="timerSec"
                        saving="state.saving"
                        onPause="() => state.showPauseModal = true"
                        onResume.bind="resumeWork"
                        onStart.bind="startWork"
                        onStop.bind="stopWork"/>
            <t t-if="state.showPauseModal">
                <PauseModal onSelect.bind="pauseWork"
                            onCancel="() => state.showPauseModal = false"/>
            </t>
        </t>

    </div>
</t>

<!-- ══════════════════════════════════════════════════════════════════
     WorkcenterSelector — machine grid
══════════════════════════════════════════════════════════════════ -->
<t t-name="dnj_shopfloor.WorkcenterSelector" owl="1">
    <div class="flex-grow-1 overflow-auto p-4 p-md-5" style="min-height:0;">

        <!-- Title -->
        <div class="text-center mb-5">
            <div style="color:#C9A227;font-size:.75rem;letter-spacing:.2em;text-transform:uppercase;margin-bottom:.5rem;">
                DNJ Drukarnia
            </div>
            <h2 class="fw-light mb-0" style="color:#E8E6D0;letter-spacing:.06em;">
                Wybierz maszynę
            </h2>
        </div>

        <t t-if="!props.workcenters.length">
            <div class="text-center mt-5" style="color:#888870;">Brak dostępnych maszyn</div>
        </t>

        <div class="row g-3 justify-content-center" style="max-width:900px;margin:auto;">
            <t t-foreach="props.workcenters" t-as="wc" t-key="wc.id">
                <div class="col-6 col-md-4 col-lg-3">
                    <button class="btn w-100 h-100 d-flex flex-column align-items-center justify-content-center gap-2 p-4"
                            style="min-height:140px;background:#1C1C12;border:2px solid #333320;border-radius:16px;color:#E8E6D0;transition:all .15s;"
                            t-on-mouseenter="(ev)=>{ev.currentTarget.style.borderColor='#C9A227';ev.currentTarget.style.background='#222215';}"
                            t-on-mouseleave="(ev)=>{ev.currentTarget.style.borderColor='#333320';ev.currentTarget.style.background='#1C1C12';}"
                            t-on-click="()=>props.onSelect(wc)">
                        <!-- machine icon -->
                        <span style="font-size:2rem;opacity:.7;">⚙</span>
                        <span class="fw-bold" style="font-size:1rem;line-height:1.2;" t-esc="wc.name"/>
                        <t t-if="wc.code">
                            <span style="font-size:.72rem;color:#C9A227;letter-spacing:.1em;text-transform:uppercase;"
                                  t-esc="wc.code"/>
                        </t>
                    </button>
                </div>
            </t>
        </div>
    </div>
</t>

<!-- ══════════════════════════════════════════════════════════════════
     PinScreen — numeric PIN pad
══════════════════════════════════════════════════════════════════ -->
<t t-name="dnj_shopfloor.PinScreen" owl="1">
    <div class="d-flex flex-column align-items-center flex-grow-1"
         style="overflow-y:auto;min-height:0;">
        <div class="d-flex flex-column align-items-center gap-4 py-4 my-auto">

        <!-- Machine name + prompt -->
        <div class="text-center">
            <div style="color:#C9A227;font-size:.75rem;letter-spacing:.15em;text-transform:uppercase;margin-bottom:.3rem;"
                 t-esc="props.workcenter ? props.workcenter.name : ''"/>
            <div class="fw-semibold" style="font-size:1.25rem;color:#E8E6D0;">
                Wprowadź PIN operatora
            </div>
        </div>

        <!-- PIN dots -->
        <div class="d-flex gap-3">
            <t t-foreach="[0,1,2,3,4,5]" t-as="i" t-key="i">
                <div t-attf-style="width:16px;height:16px;border-radius:50%;border:2px solid #C9A227;#{i &lt; state.pin.length ? 'background:#C9A227;' : ''}"/>
            </t>
        </div>

        <!-- Error / spacer -->
        <div t-if="state.error" class="fw-semibold" style="color:#e06060;" t-esc="state.error"/>
        <div t-else="" style="height:1.4rem;"/>

        <!-- Numpad -->
        <div class="d-grid gap-2" style="grid-template-columns:repeat(3,1fr);width:288px;">
            <t t-foreach="[1,2,3,4,5,6,7,8,9,'⌫',0,'✓']" t-as="key" t-key="key">
                <button class="btn fw-bold"
                        style="height:76px;border-radius:14px;font-size:1.5rem;"
                        t-attf-style="height:76px;border-radius:14px;font-size:1.5rem;#{
                            key === '✓'
                                ? 'background:#2D5C2D;color:#fff;border:2px solid #3D7C3D;'
                            : key === '⌫'
                                ? 'background:#3A1A1A;color:#e08080;border:2px solid #5A2A2A;'
                                : 'background:#1C1C12;color:#E8E6D0;border:2px solid #333320;'
                        }"
                        t-att-disabled="state.loading"
                        t-on-click="()=>onKey(key)">
                    <t t-if="state.loading and key === '✓'">
                        <span class="spinner-border spinner-border-sm"/>
                    </t>
                    <t t-else="" t-esc="key"/>
                </button>
            </t>
        </div>

        <button class="btn btn-link btn-sm" style="color:#888870;"
                t-on-click="props.onBack">
            ← Zmień maszynę
        </button>
        </div><!-- /inner centering div -->
    </div><!-- /scroll wrapper -->
</t>

<!-- ══════════════════════════════════════════════════════════════════
     WorkOrderQueue — list of pending jobs + barcode
══════════════════════════════════════════════════════════════════ -->
<t t-name="dnj_shopfloor.WorkOrderQueue" owl="1">
    <div class="d-flex flex-column flex-grow-1 overflow-hidden" style="min-height:0;">

        <!-- Toolbar -->
        <div class="d-flex align-items-center gap-3 px-4 py-2 flex-shrink-0"
             style="background:#1C1C12;border-bottom:1px solid #333320;">
            <input t-ref="barcode"
                   class="form-control form-control-sm"
                   style="max-width:280px;background:#111209;border-color:#333320;color:#E8E6D0;"
                   placeholder="🔍 Skanuj numer zlecenia + Enter"
                   t-on-keydown="onBarcodeKey"/>
            <button class="btn btn-sm"
                    style="border:1px solid #333320;color:#888870;border-radius:8px;"
                    t-on-click="props.onRefresh">↻</button>
            <span class="ms-auto" style="color:#888870;font-size:.85rem;">
                <t t-esc="props.workorders.length"/> zleceń
            </span>
        </div>

        <!-- List -->
        <div class="overflow-auto flex-grow-1 p-3">
            <t t-if="!props.workorders.length">
                <div class="text-center mt-5" style="color:#888870;font-size:1.1rem;">
                    Brak aktywnych zleceń dla tej maszyny
                </div>
            </t>
            <t t-foreach="props.workorders" t-as="wo" t-key="wo.id">
                <div class="d-flex align-items-center justify-content-between px-4 py-3 mb-2"
                     style="background:#1C1C12;border:1px solid #333320;border-radius:14px;cursor:pointer;transition:border-color .15s;"
                     t-on-mouseenter="(ev)=>ev.currentTarget.style.borderColor='#C9A227'"
                     t-on-mouseleave="(ev)=>ev.currentTarget.style.borderColor='#333320'"
                     t-on-click="()=>props.onSelect(wo)">
                    <div>
                        <div class="fw-bold" style="color:#E8E6D0;" t-esc="wo.name"/>
                        <div style="color:#888870;font-size:.875rem;"
                             t-esc="wo.product_id ? wo.product_id[1] : ''"/>
                        <div t-if="wo.production_id"
                             style="font-size:.8rem;color:#C9A227;"
                             t-esc="'MO: ' + wo.production_id[1]"/>
                    </div>
                    <div class="d-flex flex-column align-items-end gap-2">
                        <span t-attf-class="badge dnj-state-#{wo.state}"
                              t-esc="stateLabel(wo.state)"/>
                        <div style="width:110px;">
                            <div class="d-flex justify-content-between mb-1"
                                 style="font-size:.72rem;color:#888870;">
                                <span t-esc="wo.qty_produced"/>
                                <span t-esc="'/ ' + wo.qty_production"/>
                            </div>
                            <div style="height:5px;background:#333320;border-radius:3px;overflow:hidden;">
                                <div style="height:100%;background:#C9A227;border-radius:3px;transition:width .4s;"
                                     t-attf-style="width:#{progressPct(wo)}%;height:100%;background:#C9A227;border-radius:3px;"/>
                            </div>
                        </div>
                        <t t-if="wo.date_start">
                            <span style="font-size:.72rem;color:#888870;"
                                  t-esc="new Date(wo.date_start).toLocaleString('pl-PL',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'})"/>
                        </t>
                    </div>
                </div>
            </t>
        </div>
    </div>
</t>

<!-- ══════════════════════════════════════════════════════════════════
     TestPrintScreen — test print qty + confirm
══════════════════════════════════════════════════════════════════ -->
<t t-name="dnj_shopfloor.TestPrintScreen" owl="1">
    <div class="d-flex flex-column align-items-center flex-grow-1 p-3 p-md-4"
         style="overflow-y:auto;min-height:0;">
        <div class="p-4 p-md-5 text-center my-auto"
             style="background:#1C1C12;border:1px solid #333320;border-radius:20px;max-width:480px;width:100%;">

            <div class="mb-4">
                <div class="badge mb-2"
                     style="background:#2A2200;color:#C9A227;letter-spacing:.1em;text-transform:uppercase;font-size:.72rem;">
                    Próbny druk
                </div>
                <div class="fw-bold" style="font-size:1.3rem;" t-esc="props.workorder.name"/>
                <div style="color:#888870;margin-top:.3rem;"
                     t-esc="props.workorder.product_id ? props.workorder.product_id[1] : ''"/>
            </div>

            <div class="mb-4 p-3"
                 style="background:#1A2A1A;border:1px solid #2D5C2D;border-radius:12px;color:#80c080;font-size:.9rem;line-height:1.6;">
                Przed rozpoczęciem produkcji wykonaj próbny druk.<br/>
                Podaj ilość arkuszy — zostanie odjęta ze stanu magazynowego.
            </div>

            <div class="mb-4">
                <label style="color:#888870;font-size:.8rem;display:block;margin-bottom:.5rem;text-transform:uppercase;letter-spacing:.08em;">
                    Ilość arkuszy próbnych
                </label>
                <input type="number" min="0" step="1"
                       class="form-control text-center fw-bold"
                       style="font-size:2rem;background:#111209;border-color:#C9A227;color:#E8E6D0;max-width:160px;margin:auto;border-radius:12px;"
                       t-att-value="qty.value"
                       t-on-change="onChange"/>
            </div>

            <div class="d-flex gap-3 justify-content-center">
                <button class="btn px-4"
                        style="border:1px solid #555540;color:#888870;border-radius:12px;"
                        t-on-click="props.onBack">
                    ← Wróć
                </button>
                <button class="btn btn-lg px-5"
                        style="background:#2D5C2D;color:#fff;border:none;border-radius:12px;font-size:1rem;"
                        t-att-disabled="props.saving"
                        t-on-click="()=>props.onConfirm(qty.value)">
                    <t t-if="props.saving">
                        <span class="spinner-border spinner-border-sm me-2"/>
                    </t>
                    Maszyna gotowa ✓
                </button>
            </div>
        </div>
    </div>
</t>

<!-- ══════════════════════════════════════════════════════════════════
     WorkScreen — active production (timer, progress, start/pause/stop)
══════════════════════════════════════════════════════════════════ -->
<t t-name="dnj_shopfloor.WorkScreen" owl="1">
    <div class="d-flex flex-column align-items-center flex-grow-1 p-3 p-md-4"
         style="overflow-y:auto;min-height:0;">
        <div class="text-center my-auto" style="max-width:580px;width:100%;">

            <!-- WO info -->
            <div class="mb-2">
                <div class="fw-bold" style="font-size:1.3rem;" t-esc="props.workorder.name"/>
                <div style="color:#888870;margin-top:.2rem;"
                     t-esc="props.workorder.product_id ? props.workorder.product_id[1] : ''"/>
            </div>

            <!-- Timer -->
            <div class="mb-2"
                 t-attf-style="font-size:4.5rem;font-weight:700;font-variant-numeric:tabular-nums;letter-spacing:.04em;color:#{props.sessionState === 'paused' ? '#C9A227' : '#E8E6D0'};">
                <t t-esc="fmtTimer(props.timerSec)"/>
            </div>
            <div t-if="props.sessionState === 'paused'" class="badge mb-3"
                 style="background:#2A2200;color:#C9A227;font-size:.9rem;padding:.4rem 1.2rem;border-radius:8px;">
                ⏸ PAUZA
            </div>

            <!-- TIME BAR — główny wskaźnik motywacyjny -->
            <div class="mb-4 px-2">
                <div class="d-flex justify-content-between align-items-baseline mb-2">
                    <span style="font-size:.8rem;color:#888870;text-transform:uppercase;letter-spacing:.1em;">
                        Czas produkcji
                    </span>
                    <span t-attf-style="font-size:1rem;font-weight:700;color:#{timeBarColor};">
                        <t t-esc="fmtTimer(props.timerSec)"/>
                        <t t-if="plannedSec">
                            <span style="margin:0 6px;color:#555540;">/</span>
                            <t t-esc="fmtTimer(plannedSec)"/>
                            <span style="margin-left:6px;">(<t t-esc="timePct"/>%)</span>
                        </t>
                    </span>
                </div>
                <!-- bar track -->
                <div style="height:44px;background:#222218;border-radius:22px;overflow:hidden;position:relative;">
                    <div t-attf-style="width:#{timeBarWidth}%;height:100%;background:#{timeBarColor};border-radius:22px;transition:width 1s;min-width:#{props.timerSec > 0 ? 8 : 0}px;"/>
                </div>
                <t t-if="isOvertime">
                    <div class="mt-2 fw-bold text-center"
                         style="color:#c03030;font-size:1.1rem;letter-spacing:.04em;">
                        ⚠ Przekroczono: +<t t-esc="fmtTimer(overtimeSec)"/>
                    </div>
                </t>
            </div>

            <!-- Quantity bar (secondary) -->
            <t t-if="props.workorder.qty_production">
                <div class="mb-4 px-2">
                    <div class="d-flex justify-content-between mb-1"
                         style="font-size:.8rem;color:#888870;">
                        <span>Wykonano</span>
                        <span><t t-esc="props.workorder.qty_produced"/> / <t t-esc="props.workorder.qty_production"/> szt. (<t t-esc="progressPct"/>%)</span>
                    </div>
                    <div style="height:16px;background:#333320;border-radius:8px;overflow:hidden;">
                        <div t-attf-style="width:#{progressPct}%;height:100%;background:#1e3050;border-radius:8px;transition:width .5s;"/>
                    </div>
                </div>
            </t>

            <!-- Qty inputs -->
            <t t-if="props.sessionState === 'progress' or props.sessionState === 'paused'">
                <div class="d-flex gap-4 justify-content-center mb-4">
                    <div>
                        <label style="color:#888870;font-size:.75rem;display:block;margin-bottom:.3rem;text-transform:uppercase;letter-spacing:.08em;">
                            Wykonano (szt.)
                        </label>
                        <input type="number" min="0"
                               class="form-control text-center fw-bold"
                               style="font-size:1.4rem;background:#111209;border-color:#333320;color:#E8E6D0;width:130px;border-radius:10px;"
                               t-att-value="finish.qty"
                               t-on-change="onQtyChange"/>
                    </div>
                    <div>
                        <label style="color:#888870;font-size:.75rem;display:block;margin-bottom:.3rem;text-transform:uppercase;letter-spacing:.08em;">
                            Braki (szt.)
                        </label>
                        <input type="number" min="0"
                               class="form-control text-center fw-bold"
                               style="font-size:1.4rem;background:#111209;border-color:#333320;color:#e08080;width:130px;border-radius:10px;"
                               t-att-value="finish.scrap"
                               t-on-change="onScrapChange"/>
                    </div>
                </div>
            </t>

            <!-- Action buttons — large touch targets for factory floor -->
            <div class="d-flex gap-3 justify-content-center flex-wrap">

                <!-- START -->
                <t t-if="props.sessionState === 'confirmed'">
                    <button style="min-width:220px;height:90px;font-size:1.5rem;font-weight:700;background:#2D5C2D;color:#fff;border:none;border-radius:18px;letter-spacing:.05em;touch-action:manipulation;"
                            t-att-disabled="props.saving"
                            t-on-click="props.onStart">
                        <t t-if="props.saving"><span class="spinner-border me-2"/></t>
                        ▶ START
                    </button>
                </t>

                <!-- PAUSE + STOP during work -->
                <t t-if="props.sessionState === 'progress'">
                    <button style="min-width:180px;height:90px;font-size:1.4rem;font-weight:700;background:#4A3A00;color:#C9A227;border:2px solid #7A6000;border-radius:18px;touch-action:manipulation;"
                            t-att-disabled="props.saving"
                            t-on-click="props.onPause">
                        ⏸ Pauza
                    </button>
                    <button style="min-width:180px;height:90px;font-size:1.4rem;font-weight:700;background:#4A1A1A;color:#ff8080;border:2px solid #7A2A2A;border-radius:18px;touch-action:manipulation;"
                            t-att-disabled="props.saving"
                            t-on-click="onStop">
                        <t t-if="props.saving"><span class="spinner-border me-2"/></t>
                        ■ STOP
                    </button>
                </t>

                <!-- RESUME + STOP during pause -->
                <t t-if="props.sessionState === 'paused'">
                    <button style="min-width:180px;height:90px;font-size:1.4rem;font-weight:700;background:#2D5C2D;color:#fff;border:none;border-radius:18px;touch-action:manipulation;"
                            t-att-disabled="props.saving"
                            t-on-click="props.onResume">
                        ▶ Wznów
                    </button>
                    <button style="min-width:180px;height:90px;font-size:1.4rem;font-weight:700;background:#4A1A1A;color:#ff8080;border:2px solid #7A2A2A;border-radius:18px;touch-action:manipulation;"
                            t-att-disabled="props.saving"
                            t-on-click="onStop">
                        ■ STOP
                    </button>
                </t>

            </div>
        </div>
    </div>
</t>

<!-- ══════════════════════════════════════════════════════════════════
     PauseModal — reason selection overlay
══════════════════════════════════════════════════════════════════ -->
<t t-name="dnj_shopfloor.PauseModal" owl="1">
    <div class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
         style="background:rgba(0,0,0,.75);z-index:9999;">
        <div class="p-4 text-center"
             style="background:#1C1C12;border:1px solid #C9A227;border-radius:20px;min-width:340px;">
            <div class="fw-bold mb-4"
                 style="font-size:1.1rem;color:#C9A227;text-transform:uppercase;letter-spacing:.1em;">
                Powód pauzy
            </div>
            <div class="d-flex flex-column gap-2">
                <t t-foreach="REASONS" t-as="r" t-key="r.key">
                    <button class="btn btn-lg text-start"
                            style="border:1px solid #4A3A00;color:#E8E6D0;border-radius:12px;padding:.75rem 1.5rem;background:#1C1C12;"
                            t-on-mouseenter="(ev)=>{ev.currentTarget.style.background='#2A2200';ev.currentTarget.style.borderColor='#C9A227';}"
                            t-on-mouseleave="(ev)=>{ev.currentTarget.style.background='#1C1C12';ev.currentTarget.style.borderColor='#4A3A00';}"
                            t-on-click="()=>props.onSelect(r.key)"
                            t-esc="r.label"/>
                </t>
            </div>
            <button class="btn btn-link mt-3" style="color:#888870;font-size:.875rem;"
                    t-on-click="props.onCancel">Anuluj</button>
        </div>
    </div>
</t>

</templates>
